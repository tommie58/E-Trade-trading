{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn etrade_bot:app --host 0.0.0.0 --port $PORT"
  }
}
ENABLE_MARKET_HOURS_CHECK=true
BROKER_TIMEOUT_SECONDS=25
VERIFY_POSITIONS_ON_CLOSE=true     # Set to false if you get errors on SELL_CLOSE
MAX_CONTRACTS=5
LIVE_TRADING=false                 # Change to true only when ready for live trading
