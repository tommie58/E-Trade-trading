{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn etrade_bot:app --host 0.0.0.0 --port $PORT"
  }
}
ENABLE_MARKET_HOURS_CHECK=true
